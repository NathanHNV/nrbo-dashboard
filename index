<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Team Portal</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0f;--surface:#111118;--surface2:#16161f;--surface3:#1c1c28;
  --text:#e8e8f0;--text2:#9090a8;--text3:#55556a;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.1);--border3:rgba(255,255,255,0.16);
  --neon-cyan:#00e5ff;--neon-cyan-dim:rgba(0,229,255,0.1);--neon-cyan-glow:rgba(0,229,255,0.25);
  --neon-green:#39ff14;--neon-green-dim:rgba(57,255,20,0.08);
  --neon-amber:#ffb300;--neon-amber-dim:rgba(255,179,0,0.08);
  --neon-purple:#bf5fff;--neon-purple-dim:rgba(191,95,255,0.08);
  --neon-red:#ff3b5c;--neon-red-dim:rgba(255,59,92,0.08);
  --radius:10px;--radius-lg:16px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);pointer-events:none;z-index:0}

/* Ambient glow */
.glow-orb{position:fixed;border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0}
.glow-orb.a{width:600px;height:600px;top:-200px;left:-100px;background:rgba(0,229,255,0.04)}
.glow-orb.b{width:500px;height:500px;bottom:-150px;right:-100px;background:rgba(191,95,255,0.04)}

/* Header */
header{position:relative;z-index:1;padding:3rem 2rem 2rem;max-width:1100px;width:100%;margin:0 auto}
.header-inner{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.brand{}
.brand h1{font-size:28px;font-weight:500;letter-spacing:.02em;color:var(--text)}
.brand h1 span{color:var(--neon-cyan);text-shadow:0 0 20px var(--neon-cyan-glow)}
.brand p{font-size:14px;color:var(--text2);margin-top:6px}
.header-meta{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
.q-badge{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;padding:5px 14px;border-radius:99px;background:var(--neon-cyan-dim);border:0.5px solid rgba(0,229,255,0.2);color:var(--neon-cyan);letter-spacing:.03em}
.q-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--neon-cyan);box-shadow:0 0 8px var(--neon-cyan);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 8px var(--neon-cyan)}50%{opacity:.5;box-shadow:0 0 4px var(--neon-cyan)}}
.date-label{font-size:12px;color:var(--text3)}

/* Divider */
.divider{max-width:1100px;width:100%;margin:0 auto;padding:0 2rem}
.divider hr{border:none;border-top:0.5px solid var(--border2);margin-bottom:2rem}

/* Grid */
.grid-wrap{position:relative;z-index:1;max-width:1100px;width:100%;margin:0 auto;padding:0 2rem 3rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}

/* Cards */
.portal-card{background:var(--surface);border:0.5px solid var(--border2);border-radius:var(--radius-lg);padding:1.75rem;cursor:pointer;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:1rem;position:relative;overflow:hidden;transition:transform .2s,border-color .2s,box-shadow .2s}
.portal-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;opacity:.6;transition:opacity .2s}
.portal-card:hover{transform:translateY(-3px)}
.portal-card .card-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.portal-card .card-icon svg{width:22px;height:22px}
.portal-card .card-title{font-size:17px;font-weight:500;letter-spacing:.01em}
.portal-card .card-desc{font-size:13px;color:var(--text2);line-height:1.6}
.portal-card .card-arrow{margin-top:auto;font-size:12px;font-weight:500;letter-spacing:.05em;text-transform:uppercase;display:flex;align-items:center;gap:5px;opacity:.6;transition:opacity .2s,gap .2s}
.portal-card:hover .card-arrow{opacity:1;gap:8px}
.portal-card .card-tag{position:absolute;top:1.25rem;right:1.25rem;font-size:10px;font-weight:500;padding:3px 10px;border-radius:99px;letter-spacing:.06em;text-transform:uppercase}

/* Card colour themes */
.card-cyan{border-color:rgba(0,229,255,0.15);box-shadow:0 0 30px rgba(0,229,255,0.04)}
.card-cyan::before{background:linear-gradient(90deg,transparent,rgba(0,229,255,0.5),transparent)}
.card-cyan:hover{border-color:rgba(0,229,255,0.3);box-shadow:0 8px 40px rgba(0,229,255,0.08)}
.card-cyan .card-icon{background:var(--neon-cyan-dim)}
.card-cyan .card-icon svg{stroke:var(--neon-cyan)}
.card-cyan .card-arrow{color:var(--neon-cyan)}

.card-green{border-color:rgba(57,255,20,0.12);box-shadow:0 0 30px rgba(57,255,20,0.03)}
.card-green::before{background:linear-gradient(90deg,transparent,rgba(57,255,20,0.4),transparent)}
.card-green:hover{border-color:rgba(57,255,20,0.25);box-shadow:0 8px 40px rgba(57,255,20,0.06)}
.card-green .card-icon{background:var(--neon-green-dim)}
.card-green .card-icon svg{stroke:var(--neon-green)}
.card-green .card-arrow{color:var(--neon-green)}

.card-amber{border-color:rgba(255,179,0,0.12);box-shadow:0 0 30px rgba(255,179,0,0.03)}
.card-amber::before{background:linear-gradient(90deg,transparent,rgba(255,179,0,0.4),transparent)}
.card-amber:hover{border-color:rgba(255,179,0,0.25);box-shadow:0 8px 40px rgba(255,179,0,0.06)}
.card-amber .card-icon{background:var(--neon-amber-dim)}
.card-amber .card-icon svg{stroke:var(--neon-amber)}
.card-amber .card-arrow{color:var(--neon-amber)}

.card-purple{border-color:rgba(191,95,255,0.12);box-shadow:0 0 30px rgba(191,95,255,0.03)}
.card-purple::before{background:linear-gradient(90deg,transparent,rgba(191,95,255,0.4),transparent)}
.card-purple:hover{border-color:rgba(191,95,255,0.25);box-shadow:0 8px 40px rgba(191,95,255,0.06)}
.card-purple .card-icon{background:var(--neon-purple-dim)}
.card-purple .card-icon svg{stroke:var(--neon-purple)}
.card-purple .card-arrow{color:var(--neon-purple)}

/* Tag colours */
.tag-cyan{background:var(--neon-cyan-dim);color:var(--neon-cyan);border:0.5px solid rgba(0,229,255,0.2)}
.tag-amber{background:var(--neon-amber-dim);color:var(--neon-amber);border:0.5px solid rgba(255,179,0,0.2)}
.tag-purple{background:var(--neon-purple-dim);color:var(--neon-purple);border:0.5px solid rgba(191,95,255,0.2)}

/* Footer */
footer{position:relative;z-index:1;margin-top:auto;padding:1rem 2rem;border-top:0.5px solid var(--border);text-align:center;font-size:11px;color:var(--text3);letter-spacing:.04em}
</style>
</head>
<body>
<div class="glow-orb a"></div>
<div class="glow-orb b"></div>

<header>
  <div class="header-inner">
    <div class="brand">
      <h1>Team <span>Portal</span></h1>
      <p>Select a section to get started</p>
    </div>
    <div class="header-meta">
      <div class="q-badge" id="q-badge">Loading...</div>
      <div class="date-label" id="date-label"></div>
    </div>
  </div>
</header>

<div class="divider"><hr></div>

<div class="grid-wrap">

  <a href="nrbo.html" class="portal-card card-cyan">
    <div class="card-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="12" width="4" height="10" rx="1"/><rect x="9" y="7" width="4" height="15" rx="1"/><rect x="16" y="2" width="4" height="20" rx="1"/>
      </svg>
    </div>
    <div>
      <div class="card-title">NRBO Tracker</div>
      <div class="card-desc">Track net revenue by operator across Gold, Platinum and Black VIP tiers. Monitor quarterly targets and deductions in real time.</div>
    </div>
    <div class="card-arrow">Open dashboard <span>→</span></div>
    <div class="card-tag tag-cyan">Performance</div>
  </a>

  <a href="player-analysis.html" class="portal-card card-green">
    <div class="card-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="7" r="4"/><path d="M4 21c0-5 3.6-9 8-9s8 4 8 9"/>
      </svg>
    </div>
    <div>
      <div class="card-title">Player Analysis</div>
      <div class="card-desc">Deep dive into individual player behaviour, activity trends and VIP tier performance across the portfolio.</div>
    </div>
    <div class="card-arrow">Open dashboard <span>→</span></div>
    <div class="card-tag tag-cyan">Analytics</div>
  </a>

  <a href="team-dashboard.html" class="portal-card card-amber">
    <div class="card-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="7" cy="7" r="3.5"/><circle cx="17" cy="7" r="3.5"/>
        <path d="M1 21c0-4 2.7-7 6-7M23 21c0-4-2.7-7-6-7M12 21c0-4 2-6.5 0-6.5S12 17 12 21"/>
      </svg>
    </div>
    <div>
      <div class="card-title">Team Dashboard</div>
      <div class="card-desc">Overview of team performance metrics, workload distribution and key activity across the VIP management team.</div>
    </div>
    <div class="card-arrow">Open dashboard <span>→</span></div>
    <div class="card-tag tag-amber">Team</div>
  </a>

  <a href="team-guides.html" class="portal-card card-purple">
    <div class="card-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M4 4.5A2.5 2.5 0 016.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15z"/>
        <path d="M9 7h6M9 11h6M9 15h4"/>
      </svg>
    </div>
    <div>
      <div class="card-title">Team Guides</div>
      <div class="card-desc">Processes, playbooks and reference material for the VIP team. Everything you need in one place.</div>
    </div>
    <div class="card-arrow">Open page <span>→</span></div>
    <div class="card-tag tag-purple">Resources</div>
  </a>

</div>

<footer>Team Portal &mdash; Internal use only</footer>

<script>
(function(){
  const now=new Date();
  const m=now.getMonth(),q=Math.floor(m/3);
  const qNames=['Q1 (Jan–Mar)','Q2 (Apr–Jun)','Q3 (Jul–Sep)','Q4 (Oct–Dec)'];
  const qEnd=new Date(now.getFullYear(),q*3+3,0,23,59,59);
  const daysLeft=Math.ceil((qEnd-now)/864e5);
  document.getElementById('q-badge').textContent=qNames[q]+' — '+daysLeft+' days left';
  document.getElementById('date-label').textContent=now.toLocaleDateString('en-IE',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
})();
</script>
</body>
</html>
